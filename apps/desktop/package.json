{
  "name": "@clawpond/desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tauri": "tauri",
    "dist": "bash -c 'for v in /Volumes/clawpond*; do hdiutil detach \"$v\" -force 2>/dev/null; done; true' && tauri build --target universal-apple-darwin",
    "dist:mac-arm": "bash -c 'for v in /Volumes/clawpond*; do hdiutil detach \"$v\" -force 2>/dev/null; done; true' && tauri build --target aarch64-apple-darwin",
    "dist:mac-x64": "bash -c 'for v in /Volumes/clawpond*; do hdiutil detach \"$v\" -force 2>/dev/null; done; true' && tauri build --target x86_64-apple-darwin",
    "dist:win-x64": "tauri build --target x86_64-pc-windows-msvc",
    "dist:win-arm": "tauri build --target aarch64-pc-windows-msvc",
    "dist:linux-x64": "tauri build --target x86_64-unknown-linux-gnu",
    "dist:linux-arm": "tauri build --target aarch64-unknown-linux-gnu"
  },
  "dependencies": {
    "@clawpond/chattools-config": "workspace:*",
    "@clawpond/config": "workspace:*",
    "@clawpond/gateway-config": "workspace:*",
    "@clawpond/openclaw": "workspace:*",
    "@clawpond/ui": "workspace:*",
    "@tauri-apps/api": "^2",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
